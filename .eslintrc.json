{
    "env": {
        "browser": true,
        "es6": true,
        "jest": true
    },
    "parser": "babel-eslint",
    "parserOptions": {
        "ecmaVersion": 2018,
        "sourceType": "module"
    },
    "extends": ["airbnb-base"],
    "rules": {
        "no-shadow": "off",
        "no-param-reassign": "off",
        "eol-last": "off",
        "import/extensions": [
            "warn",
            {
                "js": "always",
                "json": "always"
            }
        ],
        "max-classes-per-file": ["error", 2],  // Allow up to 2 classes in a file
        "no-alert": "warn"  // Warn instead of error for alert usage
    },
    "ignorePatterns": [
        "dist/",
        "build/"
    ]
}